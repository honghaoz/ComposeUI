# rules
--enable blankLineAfterImports
--enable noForceTryInTests
--enable redundantNilInit
--enable wrapConditionalBodies
--enable wrapEnumCases
--enable wrapSwitchCases

--disable blankLinesAtStartOfScope
--disable blankLinesBetweenImports
--disable conditionalAssignment
--disable docComments
--disable emptyExtensions
--disable isEmpty
--disable preferForLoop
--disable redundantAsync
--disable redundantEquatable
--disable redundantMemberwiseInit
--disable redundantOptionalBinding
--disable redundantProperty
--disable redundantReturn
--disable redundantSelf # https://github.com/nicklockwood/SwiftFormat/issues/1438
--disable redundantThrows
--disable redundanttype
--disable redundantViewBuilder
--disable sortImports
--disable strongifiedSelf
--disable testSuiteAccessControl
--disable unusedArguments
--disable unusedPrivateDeclarations
--disable validateTestCases
--disable wrapPropertyBodies

# format options
--decimalgrouping none
--header "//\n//  {file}\n//  ComposéUI\n//\n//  {created_by}\n//"
--hexgrouping none
--ifdef no-indent
--importgrouping testable-last
--indent 2
--octalgrouping none
--patternlet inline
--semicolons never
# --self init-only # redundantSelf
# --stripunusedargs closure-only # unusedArguments

# file options
--exclude Submodules, Pods
--exclude **/_Deprecated**
--exclude **/Deprecated_**
--exclude **/_*Deprecated**
